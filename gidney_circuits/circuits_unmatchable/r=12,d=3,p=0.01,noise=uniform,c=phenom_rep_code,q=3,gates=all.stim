QUBIT_COORDS(0, 0) 0
QUBIT_COORDS(1, 0) 1
QUBIT_COORDS(2, 0) 2
MPP Z0
OBSERVABLE_INCLUDE(0) rec[-1]
MPP Z0*Z1 Z1*Z2
TICK
REPEAT 12 {
    DEPOLARIZE1(0.01) 0 1 2
    MPP(0.01) Z0*Z1 Z1*Z2
    DETECTOR(0.5, 0, 0, 3) rec[-4] rec[-2]
    DETECTOR(1.5, 0, 0, 3) rec[-3] rec[-1]
    SHIFT_COORDS(0, 0, 1)
    TICK
}
MPP Z0*Z1 Z1*Z2
DETECTOR(0.5, 0, 0, 3) rec[-4] rec[-2]
DETECTOR(1.5, 0, 0, 3) rec[-3] rec[-1]
MPP Z0
OBSERVABLE_INCLUDE(0) rec[-1]
